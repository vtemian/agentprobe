{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@agentprobe/core": ["src/index.ts"],
      "@agentprobe/core/providers/cursor": ["src/providers/cursor/index.ts"]
    },
    "outDir": "dist"
  },
  "include": ["src", "tests", "examples", "tsup.config.ts", "vitest.config.ts"]
}

{
  "name": "@agentprobe/core",
  "version": "0.1.2",
  "description": "Tool-agnostic watch runtime with transcript providers for coding agents.",
  "license": "MIT",
  "author": "Vlad Temian <vladtemian@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vtemian/agentprobe.git"
  },
  "homepage": "https://github.com/vtemian/agentprobe#readme",
  "bugs": {
    "url": "https://github.com/vtemian/agentprobe/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs",
      "default": "./dist/core/index.js"
    },
    "./providers/cursor": {
      "types": "./dist/providers/cursor/index.d.ts",
      "import": "./dist/providers/cursor/index.js",
      "require": "./dist/providers/cursor/index.cjs",
      "default": "./dist/providers/cursor/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "core": [
        "dist/core/index.d.ts"
      ],
      "providers/cursor": [
        "dist/providers/cursor/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage",
    "dev": "tsup --watch",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "biome check . && npm run typecheck && npm run test"
  },
  "keywords": [
    "watch",
    "transcripts",
    "agents",
    "codex",
    "claude",
    "cursor",
    "opencode"
  ],
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/node": "^25.3.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}

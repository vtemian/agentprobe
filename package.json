{
  "name": "@agent-io/core",
  "version": "0.1.0",
  "description": "Tool-agnostic watch runtime with transcript providers for coding agents.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./providers/cursor": {
      "types": "./dist/providers/cursor/index.d.ts",
      "import": "./dist/providers/cursor/index.js",
      "require": "./dist/providers/cursor/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage",
    "dev": "tsup --watch",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "biome check . && npm run typecheck && npm run test"
  },
  "keywords": [
    "watch",
    "transcripts",
    "agents",
    "codex",
    "claude",
    "cursor",
    "opencode"
  ],
  "dependencies": {
    "lodash-es": "^4.17.23",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
